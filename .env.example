# Hybrid XAI — optional; template fallback always works without any keys

# Browser → Ollama (local dev only — set NEXT_PUBLIC_OLLAMA_ENABLED=true)
# Requires Ollama CORS: set OLLAMA_ORIGINS=http://localhost:3000 and restart Ollama
NEXT_PUBLIC_OLLAMA_ENABLED=false
NEXT_PUBLIC_OLLAMA_BASE_URL=http://127.0.0.1:11434
NEXT_PUBLIC_OLLAMA_MODEL=gemma4:e2b
# NEXT_PUBLIC_OLLAMA_TIMEOUT_MS=120000
# GPU layers to offload (999 = max VRAM — GPU-first; 0 = CPU-only)
NEXT_PUBLIC_OLLAMA_NUM_GPU=999

# Server-side Ollama (optional fallback if API route called without skipOllama)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
# OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_GPU=999

# Cloud LLM (tried if Ollama unavailable or disabled)
# Use a Google AI Studio key (https://aistudio.google.com/apikey) — usually starts with AIza
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash

# OpenStreetMap / Overpass (optional POI overlay on the outlet map)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# NEXT_PUBLIC_MAP_POI_OVERLAY=off
# NEXT_PUBLIC_MAP_DEFAULT_ZOOM=8

# Production data plane (Neon Postgres) — optional in Phase 1; falls back to public/data/outlets.json
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
